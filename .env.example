# Required for Gemini image generation. Admin UI stores active keys in the DB.
GEMINI_API_KEY=your-gemini-api-key

# Required for JWT signing. Use at least 32 characters.
JWT_SECRET=change-this-jwt-secret-to-at-least-32-characters

# Required for encrypting admin-managed API keys.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=replace-with-64-character-hex-string

# Tailscale deployment defaults.
NEXT_PUBLIC_API_URL=http://100.69.75.47:4000
CORS_ORIGIN=*
